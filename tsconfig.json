{
  "compilerOptions": {
    "target": "ES2016",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "src/matika/static/js",
    "rootDir": "src/frontend",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ES2016"],
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/frontend/**/*.ts"]
}
