# Copy this file to .env and fill in the values.
# The application will refuse to start if SECRET_KEY is not set.
# Never commit .env — it is gitignored.

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# OPTIONAL — defaults to SQLite in the data/ directory
# DATABASE_URL=postgresql://user:password@host:5432/matika

# OPTIONAL — OAuth providers (leave blank to disable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Set to "development" during local development only.
# Relaxes the applug matika_version check so a _dev version of matika
# is compatible with applugs that declare the corresponding released version.
# Never set this in production.
MATIKA_ENV=development
