# Copy this file to .env and fill in the values.
# The application will refuse to start if SECRET_KEY is not set.
# Never commit .env — it is gitignored.

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# OPTIONAL — defaults to SQLite in the data/ directory
# DATABASE_URL=postgresql://user:password@host:5432/matika

# OPTIONAL — OAuth providers (leave blank to disable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Note: there is no MATIKA_ENV version escape hatch. AppLug compatibility is
# decided purely on the bare version CORE (X.Y.Z): the pre-release suffix
# (-dev, -rc.N) is stripped from BOTH the running version and the applug's
# matika_version before comparison. A pre-release runtime (e.g. 0.0.4-dev)
# loads any AppLug pinned to its bare core (0.0.4) automatically.
