{
  "name": "@manomatika/matika-frontend",
  "version": "0.0.0",
  "description": "Frontend TypeScript primitives for Matika applugs",
  "type": "module",
  "main": "src/matika/static/js/index.js",
  "module": "src/matika/static/js/index.js",
  "types": "src/matika/static/js/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/matika/static/js/index.d.ts",
      "import": "./src/matika/static/js/index.js"
    }
  },
  "files": [
    "src/matika/static/js/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "husky || true"
  },
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manomatika/matika.git"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  }
}
